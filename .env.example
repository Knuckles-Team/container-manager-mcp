# ==============================================================================
# Container Manager Mcp Environment Configuration
# ==============================================================================

# --- MCP Server Settings ---
HOST=0.0.0.0
PORT=8000
TRANSPORT=stdio # options: stdio, streamable-http, sse

# --- Telemetry & Observability (OTEL / Langfuse) ---
ENABLE_OTEL=True
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:8080/api/public/otel
# OTEL_EXPORTER_OTLP_PUBLIC_KEY=pk-...
# OTEL_EXPORTER_OTLP_SECRET_KEY=sk-...
# OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf

# --- Enterprise Security & Access Governance (Eunomia) ---
EUNOMIA_TYPE=none # options: none, embedded, remote
EUNOMIA_POLICY_FILE=mcp_policies.json
# EUNOMIA_REMOTE_URL=http://eunomia-server:8000

# --- Core Container-Manager Settings ---
CONTAINER_MANAGER_TYPE=docker # options: docker, podman, swarm, kubernetes
CONTAINER_MANAGER_HOST= # remote docker daemon host (e.g. tcp://host:2375); empty = local
CONTAINER_MANAGER_PODMAN_BASE_URL= # podman service base URL (e.g. unix:///run/podman/podman.sock)

# --- Kubernetes Backend (when CONTAINER_MANAGER_TYPE=kubernetes) ---
CONTAINER_MANAGER_KUBECONTEXT= # kubeconfig context name; empty = current-context
KUBERNETES_SERVICE_HOST= # injected by the cluster when running in-pod; leave empty

# --- Tool Toggle Switches ---
INVENTORYTOOL=True
INFOTOOL=True
IMAGETOOL=True
CONTAINERTOOL=True
VOLUMETOOL=True
NETWORKTOOL=True
SWARMTOOL=True
SYSTEMTOOL=True
COMPOSETOOL=True
MISCTOOL=True
SPECIALIST_DEPLOYMENTTOOL=True
K8SRESOURCETOOL=True
K8SRBACTOOL=True
K8SNETWORKINGTOOL=True
K8STORAGETOOL=True
K8SADVANCEDTOOL=True
K8SSYSTEMTOOL=True
K8SMONITORINGTOOL=True
K8SCRDTOOL=True
K8SADVANCEDRESOURCESTOOL=True
K8SADVANCEDRBACTOOL=True
K8SADVANCEDNETWORKINGTOOL=True
K8SADVANCEDSTORAGETOOL=True
K8SADVANCEDSCHEDULINGTOOL=True
K8SADVANCEDSTATETOOL=True
K8SADVANCEDCOMPREHENSIVETOOL=True
PODMANADVANCEDTOOL=True
DOCKERADVANCEDTOOL=True
K8SREMAININGGAPSTOOL=True
MULTICONTEXTTOOL=True

# Multi-Context Configuration
MULTI_CONTEXT_MODE=True

# Kubernetes Contexts (format: "context1=kubeconfig_context;context2=another_context")
# Example: "dev=dev-cluster;prod=prod-cluster;staging=staging-cluster"
K8S_CONTEXTS=

# Default Kubernetes context name (must match a key in K8S_CONTEXTS)
DEFAULT_K8S_CONTEXT=

# Docker Contexts (format: "context1=tcp://host:port;context2=tcp://another:port")
# Example: "local=unix:///var/run/docker.sock;remote=tcp://192.168.1.100:2375"
DOCKER_CONTEXTS=

# Default Docker context name (must match a key in DOCKER_CONTEXTS)
DEFAULT_DOCKER_CONTEXT=

# Swarm Contexts (format: "context1=tcp://host:port;context2=tcp://another:port")
# Example: "swarm1=tcp://swarm1:2375;swarm2=tcp://swarm2:2375"
SWARM_CONTEXTS=

# Default Swarm context name (must match a key in SWARM_CONTEXTS)
DEFAULT_SWARM_CONTEXT=

# Enable Podman (local only)
PODMAN_ENABLED=true
