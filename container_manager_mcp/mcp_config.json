        "CONTAINER_MANAGER_KUBECONTEXT": "",
        "CONTAINER_MANAGER_PODMAN_BASE_URL": "",
        "CONTAINER_MANAGER_TYPE": "docker",
        "DEFAULT_DOCKER_CONTEXT": "",
