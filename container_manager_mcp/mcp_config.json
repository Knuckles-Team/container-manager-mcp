        "DOCKER_CONTEXTS": "",
        "HEALTH_CHECK_TTL_SECONDS": "30",
        "IMAGETOOL": "True",
        "INFOTOOL": "True",
        "INVENTORYTOOL": "True",
        "K8SCLUSTERTOOL": "True",
        "K8SCONFIGTOOL": "True",
        "K8SGOVERNANCETOOL": "True",
        "K8SNETWORKINGTOOL": "True",
        "K8SOBSERVABILITYTOOL": "True",
