    "server": "container-manager-mcp",
    "tool": "cm_container_operations",
    "params_style": "args",
    "action": "list_containers",
    "params": { "all_containers": true },
    "records_path": "",
    "id_field": "id",
    "title_field": "name",
    "text_field": "image",
    "updated_field": "created",
    "doc_type": "container"
  },
