@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix dc: <http://purl.org/dc/terms/> .
@prefix : <http://knuckles.team/kg#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# Container-manager ontology — Docker / Podman / Swarm resource model backing the
# container-manager-mcp tool surface (cm_container_operations / cm_image_operations /
# cm_volume_operations / cm_network_operations / cm_swarm_operations / cm_compose_operations).
# All classes and properties live in the shared `:` (kg#) namespace; only the owl:Ontology
# node gets the per-package IRI.
#
# REUSE (defined in the hub's ontology_infrastructure.ttl — NOT redefined here):
#   :Container       — a running container instance (Docker/Podman/containerd/CRI-O)
#   :ContainerImage  — an OCI image / repository:tag
#   :ContainerStack  — a compose/stack grouping of containers
#   :Host            — a reachable host in the tunnel-manager inventory
# and the links :runsOn (Container->Host), :belongsToStack (Container->ContainerStack),
# and the field :runtime. This leg only adds the volume / network / swarm resources and
# the container-scoped links/fields the connector materializes.
#
# REUSE (defined in portainer_agent's portainer.ttl — NOT redefined here):
#   :Repository — the git source repository an artifact was built/deployed from.

# --- net-new classes (owl:Class) ---

:ContainerVolume a owl:Class ;
    rdfs:label "Container Volume" ;
    rdfs:comment "A named persistent storage volume mounted into containers (cm_volume_operations: list_volumes / create_volume)." .

:ContainerNetwork a owl:Class ;
    rdfs:label "Container Network" ;
    rdfs:comment "A container network (bridge/overlay/macvlan/host) that containers attach to (cm_network_operations: list_networks / create_network)." .

:SwarmService a owl:Class ;
    rdfs:label "Swarm Service" ;
    rdfs:comment "A Docker Swarm replicated/global service — a desired-state deployment of a container image across the cluster (cm_swarm_operations: list_services / create_service / scale_service)." .

:SwarmNode a owl:Class ;
    rdfs:label "Swarm Node" ;
    rdfs:comment "A node participating in a Docker Swarm cluster, with a manager/worker role (cm_swarm_operations: list_nodes)." .

# --- net-new Kubernetes classes (owl:Class) ---
# Materialized by the cm_k8s_* themed tools (cm_k8s_workloads / cm_k8s_config /
# cm_k8s_networking / cm_k8s_cluster) via cm_ingest_inventory and the connector presets.

:Pod a owl:Class ;
    rdfs:label "Kubernetes Pod" ;
    rdfs:comment "A Kubernetes Pod — the smallest schedulable unit, one or more co-located containers (cm_k8s_workloads: list_pods / describe_pod)." .

:Deployment a owl:Class ;
    rdfs:label "Kubernetes Deployment" ;
    rdfs:comment "A Kubernetes Deployment — declarative desired-state ReplicaSet controller for Pods (cm_k8s_workloads: list_services / create_service)." .

:StatefulSet a owl:Class ;
    rdfs:label "Kubernetes StatefulSet" ;
    rdfs:comment "A Kubernetes StatefulSet — ordered, stable-identity Pod controller for stateful workloads (cm_k8s_workloads)." .

:DaemonSet a owl:Class ;
    rdfs:label "Kubernetes DaemonSet" ;
    rdfs:comment "A Kubernetes DaemonSet — runs a Pod copy on every (or selected) K8sNode (cm_k8s_workloads)." .

:K8sService a owl:Class ;
    rdfs:label "Kubernetes Service" ;
    rdfs:comment "A native Kubernetes (core/v1) Service exposing a set of Pods (ClusterIP/NodePort/LoadBalancer) (cm_k8s_networking: list_k8s_services)." .

:Namespace a owl:Class ;
    rdfs:label "Kubernetes Namespace" ;
    rdfs:comment "A Kubernetes Namespace — a virtual cluster partition scoping most namespaced resources (cm_k8s_config: list_namespaces)." .

:K8sNode a owl:Class ;
    rdfs:label "Kubernetes Node" ;
    rdfs:comment "A Kubernetes worker/control-plane Node onto which Pods are scheduled (cm_k8s_cluster: list_nodes)." .

:Ingress a owl:Class ;
    rdfs:label "Kubernetes Ingress" ;
    rdfs:comment "A Kubernetes Ingress — HTTP(S) routing rules exposing K8sServices externally (cm_k8s_networking: list_ingress)." .

# --- links (owl:ObjectProperty) ---

:usesImage a owl:ObjectProperty ;
    rdfs:label "uses image" ;
    rdfs:comment "Links a Container, SwarmService, Pod or Deployment to the ContainerImage it was created from." ;
    rdfs:range :ContainerImage .

:builtFrom a owl:ObjectProperty ;
    rdfs:label "built from" ;
    rdfs:comment "Links a ContainerImage to the source-code Repository it was built from, resolved from the image's OCI org.opencontainers.image.source label (org.label-schema.vcs-url fallback) via cm_ingest_inventory. The gap-#1 predicate closing the service<->repo<->image provenance chain (reports/autonomous-sdlc-loop-design.md); agent_utilities.observability.repo_crosswalk owl:sameAs-unifies the resulting URL-keyed Repository node with the numeric-id node the code ingestors (github-agent/gitlab-api) create." ;
    rdfs:domain :ContainerImage ;
    rdfs:range :Repository .

:mountsVolume a owl:ObjectProperty ;
    rdfs:label "mounts volume" ;
    rdfs:comment "Links a Container to a ContainerVolume it mounts." ;
    rdfs:domain :Container ;
    rdfs:range :ContainerVolume .

:attachedToNetwork a owl:ObjectProperty ;
    rdfs:label "attached to network" ;
    rdfs:comment "Links a Container or SwarmService to a ContainerNetwork it is attached to." ;
    rdfs:range :ContainerNetwork .

:scheduledOnNode a owl:ObjectProperty ;
    rdfs:label "scheduled on node" ;
    rdfs:comment "Links a Container task or SwarmService replica to the SwarmNode it runs on." ;
    rdfs:range :SwarmNode .

:hostsResource a owl:ObjectProperty ;
    rdfs:label "hosts resource" ;
    rdfs:comment "Links a Host to a Container, ContainerVolume, ContainerNetwork or SwarmNode it hosts." ;
    rdfs:domain :Host .

# --- Kubernetes links (owl:ObjectProperty) ---

:runsInNamespace a owl:ObjectProperty ;
    rdfs:label "runs in namespace" ;
    rdfs:comment "Links a namespaced Kubernetes resource (Pod, Deployment, K8sService) to the Namespace that scopes it." ;
    rdfs:range :Namespace .

:managedByDeployment a owl:ObjectProperty ;
    rdfs:label "managed by deployment" ;
    rdfs:comment "Links a Pod to the Deployment (via its ReplicaSet) that owns and manages it." ;
    rdfs:domain :Pod ;
    rdfs:range :Deployment .

:scheduledOnK8sNode a owl:ObjectProperty ;
    rdfs:label "scheduled on k8s node" ;
    rdfs:comment "Links a Pod to the K8sNode the scheduler placed it on." ;
    rdfs:domain :Pod ;
    rdfs:range :K8sNode .

:exposedByIngress a owl:ObjectProperty ;
    rdfs:label "exposed by ingress" ;
    rdfs:comment "Links a K8sService to an Ingress that routes external HTTP(S) traffic to it." ;
    rdfs:domain :K8sService ;
    rdfs:range :Ingress .

# --- fields (owl:DatatypeProperty) ---

:containerStatus a owl:DatatypeProperty ;
    rdfs:label "container status" ;
    rdfs:comment "Lifecycle status of a Container (running, exited, paused, created)." ;
    rdfs:domain :Container ;
    rdfs:range xsd:string .

:portMappings a owl:DatatypeProperty ;
    rdfs:label "port mappings" ;
    rdfs:comment "Published host->container port mappings of a Container or SwarmService (e.g. 0.0.0.0:8080->80/tcp)." ;
    rdfs:range xsd:string .

:imageRepository a owl:DatatypeProperty ;
    rdfs:label "image repository" ;
    rdfs:comment "Repository component of a ContainerImage reference (registry/namespace/name)." ;
    rdfs:domain :ContainerImage ;
    rdfs:range xsd:string .

:imageTag a owl:DatatypeProperty ;
    rdfs:label "image tag" ;
    rdfs:comment "Tag component of a ContainerImage reference (e.g. latest, 1.29.1)." ;
    rdfs:domain :ContainerImage ;
    rdfs:range xsd:string .

:imageSize a owl:DatatypeProperty ;
    rdfs:label "image size" ;
    rdfs:comment "Human-readable on-disk size of a ContainerImage (e.g. 142MB)." ;
    rdfs:domain :ContainerImage ;
    rdfs:range xsd:string .

:volumeDriver a owl:DatatypeProperty ;
    rdfs:label "volume driver" ;
    rdfs:comment "Storage driver backing a ContainerVolume (local, nfs, …)." ;
    rdfs:domain :ContainerVolume ;
    rdfs:range xsd:string .

:mountpoint a owl:DatatypeProperty ;
    rdfs:label "mountpoint" ;
    rdfs:comment "Host filesystem path where a ContainerVolume is materialized." ;
    rdfs:domain :ContainerVolume ;
    rdfs:range xsd:string .

:networkDriver a owl:DatatypeProperty ;
    rdfs:label "network driver" ;
    rdfs:comment "Driver of a ContainerNetwork (bridge, overlay, macvlan, host, none)." ;
    rdfs:domain :ContainerNetwork ;
    rdfs:range xsd:string .

:networkScope a owl:DatatypeProperty ;
    rdfs:label "network scope" ;
    rdfs:comment "Scope of a ContainerNetwork (local or swarm)." ;
    rdfs:domain :ContainerNetwork ;
    rdfs:range xsd:string .

:serviceReplicas a owl:DatatypeProperty ;
    rdfs:label "service replicas" ;
    rdfs:comment "Desired replica count of a replicated SwarmService." ;
    rdfs:domain :SwarmService ;
    rdfs:range xsd:integer .

:nodeRole a owl:DatatypeProperty ;
    rdfs:label "node role" ;
    rdfs:comment "Role of a SwarmNode in the cluster (manager or worker)." ;
    rdfs:domain :SwarmNode ;
    rdfs:range xsd:string .

:nodeAvailability a owl:DatatypeProperty ;
    rdfs:label "node availability" ;
    rdfs:comment "Scheduling availability of a SwarmNode (active, pause, drain)." ;
    rdfs:domain :SwarmNode ;
    rdfs:range xsd:string .

:externalToolId a owl:DatatypeProperty ;
    rdfs:label "external tool id" ;
    rdfs:comment "Native identifier of the resource in its container engine (container id, image id, volume name, service id, node id)." ;
    rdfs:range xsd:string .

# --- Kubernetes fields (owl:DatatypeProperty) ---

:podPhase a owl:DatatypeProperty ;
    rdfs:label "pod phase" ;
    rdfs:comment "Lifecycle phase of a Pod (Pending, Running, Succeeded, Failed, Unknown)." ;
    rdfs:domain :Pod ;
    rdfs:range xsd:string .

:deploymentReplicas a owl:DatatypeProperty ;
    rdfs:label "deployment replicas" ;
    rdfs:comment "Desired replica count of a Deployment." ;
    rdfs:domain :Deployment ;
    rdfs:range xsd:integer .

:deploymentReadyReplicas a owl:DatatypeProperty ;
    rdfs:label "deployment ready replicas" ;
    rdfs:comment "Number of ready replicas currently reported by a Deployment's status." ;
    rdfs:domain :Deployment ;
    rdfs:range xsd:integer .

:serviceType a owl:DatatypeProperty ;
    rdfs:label "service type" ;
    rdfs:comment "Type of a K8sService (ClusterIP, NodePort, LoadBalancer)." ;
    rdfs:domain :K8sService ;
    rdfs:range xsd:string .

:namespaceStatus a owl:DatatypeProperty ;
    rdfs:label "namespace status" ;
    rdfs:comment "Lifecycle phase of a Namespace (Active, Terminating)." ;
    rdfs:domain :Namespace ;
    rdfs:range xsd:string .

:nodeCapacity a owl:DatatypeProperty ;
    rdfs:label "node capacity" ;
    rdfs:comment "Total advertised compute resources of a K8sNode (cpu/memory/pods)." ;
    rdfs:domain :K8sNode ;
    rdfs:range xsd:string .

:nodeAllocatable a owl:DatatypeProperty ;
    rdfs:label "node allocatable" ;
    rdfs:comment "Schedulable (allocatable) compute resources of a K8sNode after system reservations." ;
    rdfs:domain :K8sNode ;
    rdfs:range xsd:string .

<http://knuckles.team/kg/container> a owl:Ontology ;
    rdfs:label "Container Manager Ontology" ;
    rdfs:comment """Container-runtime resource model for the container-manager-mcp connector —
    Docker / Podman / Swarm containers, images, volumes, networks, swarm services and nodes,
    with their usesImage / mountsVolume / attachedToNetwork / scheduledOnNode / builtFrom
    relationships (builtFrom resolves a ContainerImage's OCI source label to its Repository).
    Also covers the Kubernetes surface — :Pod / :Deployment / :StatefulSet / :DaemonSet /
    :K8sService / :Namespace / :K8sNode / :Ingress with runsInNamespace / managedByDeployment /
    scheduledOnK8sNode / exposedByIngress — materialized by the cm_k8s_* themed tools
    (cm_k8s_workloads / cm_k8s_config / cm_k8s_networking / cm_k8s_storage / cm_k8s_rbac /
    cm_k8s_cluster / cm_k8s_governance / cm_k8s_observability) via cm_ingest_inventory.
    Reuses the hub :Container / :ContainerImage / :ContainerStack / :Host classes and adds the
    volume/network/swarm/k8s resources, federated into the agent-utilities knowledge-graph hub.""" ;
    owl:imports <http://knuckles.team/kg> .
